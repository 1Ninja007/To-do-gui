<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: #535744;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.todoapp.controller.TasksController">
   <children>
      <AnchorPane layoutY="99.0" prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #7e826c;">
         <children>
            <TableView fx:id="tasksTableView" layoutX="20.0" layoutY="25.0" prefHeight="250.0" prefWidth="760.0" style="-fx-border-color: #5c5349; -fx-background-color: #5c5349; -fx-border-width: 1;">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy></TableView>
            <Button fx:id="deletaTaskButton" layoutX="241.0" layoutY="296.0" mnemonicParsing="false" onAction="#onDeleteTaskButtonClick" style="-fx-background-color: #5c5349; -fx-background-radius: 10;" text="Delete task" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="18.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
            <Button fx:id="showDetailsButton" layoutX="422.0" layoutY="296.0" mnemonicParsing="false" onAction="#onShowDetailsButtonClick" style="-fx-background-color: #5c5349; -fx-background-radius: 10;" text="Show details" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="18.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
      </AnchorPane>
      <Label layoutX="275.0" layoutY="14.0" text="To Do App" textFill="#2b2621">
         <font>
            <Font name="Arial Black" size="48.0" />
         </font>
      </Label>
      <Button fx:id="addButton" layoutX="721.0" layoutY="28.0" mnemonicParsing="false" onAction="#onAddButtonClick" style="-fx-background-color: #2b2621; -fx-background-radius: 10;" text="+" textFill="#5c5349">
         <font>
            <Font name="Arial Black" size="20.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
   </children>
</AnchorPane>
