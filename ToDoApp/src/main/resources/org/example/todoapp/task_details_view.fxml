            <Font name="Arial Black" size="48.0" />
         </font>
      </Label>
      <Button fx:id="returnButtonaddButton" layoutX="661.0" layoutY="28.0" mnemonicParsing="false" onAction="#onReturnButtonClick" style="-fx-background-color: #2b2621; -fx-background-radius: 10;" text="Return" textFill="#5c5349">
         <font>
            <Font name="Arial Black" size="20.0" />
         </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
      </Button>
   </children>
</AnchorPane>
