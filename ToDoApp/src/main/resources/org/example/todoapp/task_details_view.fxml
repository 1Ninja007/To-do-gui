<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: #535744;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.todoapp.controller.TaskDetailsController">
   <children>
      <AnchorPane fx:id="tloAnchorPane" layoutY="99.0" prefHeight="350.0" prefWidth="800.0" style="-fx-background-color: #7e826c;">
         <children>
            <Label fx:id="titleLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="376.0" layoutY="21.0" style="-fx-background-color: #5c5349; -fx-background-radius: 4;" text="Title" textAlignment="CENTER" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="24.0" />
               </font>
               <padding>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </padding>
            </Label>
            <Label fx:id="descriptionLabel" alignment="TOP_LEFT" contentDisplay="CENTER" layoutX="319.0" layoutY="87.0" prefHeight="146.0" prefWidth="194.0" style="-fx-background-color: #5c5349; -fx-background-radius: 4;" text="Description" textAlignment="CENTER" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </padding>
            </Label>
            <Label fx:id="dateLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="388.0" layoutY="259.0" style="-fx-background-color: #5c5349; -fx-background-radius: 4;" text="Date" textAlignment="CENTER" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </padding>
            </Label>
            <Label fx:id="priorityLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="378.0" layoutY="303.0" style="-fx-background-color: #5c5349; -fx-background-radius: 4;" text="Priority" textAlignment="CENTER" textFill="#2b2621">
               <font>
                  <Font name="Arial Black" size="14.0" />
               </font>
               <padding>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </padding>
            </Label>
         </children>
      </AnchorPane>
      <Label layoutX="275.0" layoutY="14.0" text="To Do App" textFill="#2b2621">
